      "surface": "webapp",
      "title": "Deep-link, refresh, and use Back/Forward",
      "type": "Regression",
      "priority": "P1",
      "riskTags": ["navigation", "state-management"],
      "cadence": ["nightly"],
      "owner": "maya",
      "navigation": "Membership → Groups (IdP)",
      "preconditions": ["User is authenticated and on the Groups (IdP) tab"],
      "steps": [
        {
          "number": 1,
          "action": "Deep-link to the Groups (IdP) tab, refresh, switch to another tab, then use Back/Forward."
        }
      ],
      "assertions": [
        "Groups (IdP) remains selected throughout; the empty state does not show stale members, roles, or groups from another tenant."
      ],
      "cleanup": {
        "required": false,
