  "testcases": [
    {
      "id": "IDP-SMK01",
      "pageId": "groups-idp",
      "surface": "webapp",
      "title": "Load cold",
      "type": "Smoke",
      "priority": "P1",
      "riskTags": ["ui-rendering", "navigation"],
      "cadence": ["deploy", "nightly"],
      "owner": "arjun",
      "navigation": "Membership → Groups (IdP)",
      "preconditions": ["User is authenticated as an enterprise admin"],
      "steps": [
        {
          "number": 1,
          "action": "Load the Groups (IdP) tab deep-linked as the first page entry."
        }
      ],
      "assertions": [
        "Groups (IdP) tab is selected with count zero; the empty state and IdP/SSO setup guidance render without page errors."
      ],
      "cleanup": {
        "required": false,
        "steps": []
      },
      "environment": {
        "targets": ["desktop-chrome"],
        "roles": ["enterprise-admin"]
      },
      "executors": {
        "devinBrowser": "eligible",
        "playwright": "eligible"
      },
      "automation": {
        "status": "active",
