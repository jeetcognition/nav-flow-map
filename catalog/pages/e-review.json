    {
      "id": "REV-SMK01",
      "pageId": "e-review",
      "surface": "webapp",
      "title": "Load cold",
      "type": "Smoke",
      "priority": "P1",
      "riskTags": ["ui-rendering", "navigation"],
      "cadence": ["deploy", "nightly"],
      "owner": "jeet",
      "navigation": "Settings → Review",
      "preconditions": ["User is authenticated as an enterprise admin"],
      "steps": [
        {
          "number": 1,
          "action": "Load the Review settings page cold."
        }
      ],
      "assertions": [
        "Devin Review settings, PR descriptions, security scan, PR comments, findings categories, GitHub CI checks, automatic review, auto-review limits, rules/files, repositories list, and self-enrolled users render without page errors."
      ],
      "cleanup": {
        "required": false,
        "steps": []
      },
      "environment": {
        "targets": ["desktop-chrome"],
        "roles": ["enterprise-admin"]
      },
      "executors": {
        "devinBrowser": "eligible",
        "playwright": "eligible"
      },
      "automation": {
        "status": "active",
        "specPath": "tests/playwright/specs/authenticated/e-review.spec.ts"
      },
