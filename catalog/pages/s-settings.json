      "surface": "webapp",
      "title": "Open Sub-orgs and Settings root cold.",
      "type": "Smoke",
      "priority": "P1",
      "riskTags": ["ui-rendering"],
      "cadence": ["deploy"],
      "owner": "arjun",
      "navigation": "Settings → Organizations → `jeet-test-org`",
      "preconditions": ["User is authenticated as an enterprise admin"],
      "steps": [
        {
          "number": 1,
          "action": "Open Sub-orgs and Settings root cold."
        }
      ],
      "assertions": [
        "Sub-org heading, preferences/settings copy, Products, Resources, Administration sections, and child links render without page errors."
      ],
      "cleanup": {
        "required": false,
        "steps": []
      },
      "environment": {
