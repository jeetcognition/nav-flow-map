  "testcases": [
    {
      "id": "SUP-SAN01",
      "pageId": "support",
      "surface": "webapp",
      "title": "From the Landing search page, open the left sidebar and click the (?) help control in the bottom-right corner.",
      "type": "Sanity",
      "priority": "P2",
      "riskTags": ["ui-rendering", "navigation"],
      "cadence": ["deploy", "nightly"],
      "owner": "arjun",
      "navigation": "Left sidebar \u2192 bottom-right (?) help \u2192 Support",
      "preconditions": ["User is authenticated as an enterprise admin"],
      "steps": [
        {
          "number": 1,
          "action": "From the Landing search page, open the left sidebar and click the (?) help control in the bottom-right corner."
        },
        {
          "number": 2,
          "action": "Click Support to open /org/cog-enterprise-qa/settings/support."
        },
        {
          "number": 3,
          "action": "Click the support-chat launcher on the Support page."
        }
      ],
      "assertions": [
        "Support chat widget opens and is ready to accept a message; no console errors."
      ],
      "cleanup": {
        "required": true,
        "steps": ["Return to the starting page and reset to a clean state"]
      },
      "environment": {
        "targets": ["desktop-chrome"],
        "roles": ["enterprise-admin"]
      },
      "executors": {
        "devinBrowser": "eligible",
        "playwright": "eligible"
      },
      "automation": {
        "status": "active",
        "specPath": "tests/playwright/specs/authenticated/support.spec.ts"
      },
      "source": {
        "type": "migration",
        "reference": "app/src/data/fixtures/testcases.json"
      },
