  "testcases": [
    {
      "id": "SUP-SAN01",
      "pageId": "support",
      "surface": "webapp",
      "title": "Open the support chat widget from the Support page",
      "type": "Sanity",
      "priority": "P2",
      "riskTags": ["navigation", "ui-rendering"],
      "cadence": ["deploy", "nightly"],
      "owner": "arjun",
      "navigation": "Left sidebar → bottom-right (?) help → Support",
      "preconditions": ["User is authenticated and on the Support page"],
      "steps": [
        {
          "number": 1,
          "action": "From the Landing search page, open the left sidebar and click the (?) help control in the bottom-right corner."
        },
        {
          "number": 2,
          "action": "Click Support to open the Support page."
        },
        {
          "number": 3,
          "action": "Click the support-chat launcher on the Support page."
        }
      ],
      "assertions": [
        "Support chat widget opens and is ready to accept a message; no console errors."
      ],
      "cleanup": {
        "required": false,
        "steps": []
      },
      "environment": {
        "targets": ["desktop-chrome"],
        "roles": ["enterprise-admin"]
      },
      "executors": {
        "devinBrowser": "required",
        "playwright": "blocked",
        "blockedReason": "Pylon chat widget is not loaded in the QA tenant; the page shows \"Support chat is unavailable\" instead of a launcher."
      },
      "automation": {
        "status": "manual",
        "specPath": null
      },
      "source": {
        "type": "migration",
        "reference": "app/src/data/fixtures/testcases.json"
      },
      "linkedBugIds": [],
      "externalReferences": [],
      "version": 1,
      "lastReviewed": "2026-07-21"
    },
