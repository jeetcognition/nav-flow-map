{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jeetcognition.github.io/nav-flow-map/catalog/schema/page-catalog.schema.json",
  "title": "Nav Flow page testcase catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "page",
    "testcases"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "page": {
      "$ref": "#/definitions/page"
    },
    "testcases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/testcase"
      }
    }
  },
  "definitions": {
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "route",
        "prefixes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "route": {
          "type": "string",
          "minLength": 1
        },
        "prefixes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z][A-Z0-9]*)*$"
          }
        }
      }
    },
    "testcase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "pageId",
        "surface",
        "title",
        "type",
        "priority",
        "riskTags",
        "cadence",
        "owner",
        "navigation",
        "preconditions",
        "steps",
        "assertions",
        "cleanup",
        "environment",
        "executors",
        "automation",
        "source",
        "linkedBugIds",
        "externalReferences",
        "version",
        "lastReviewed"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z][A-Z0-9]*)*-(?:SMK|SAN|REG|E2E)[0-9]{2}$"
        },
        "pageId": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "surface": {
          "const": "webapp"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "Smoke",
            "Sanity",
            "Regression",
            "E2E"
          ]
        },
        "priority": {
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3"
          ]
        },
        "riskTags": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          }
        },
        "cadence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "deploy",
              "nightly",
              "weekly",
              "release",
              "change-triggered",
              "on-demand"
            ]
          }
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "navigation": {
          "type": "string",
          "minLength": 1
        },
        "preconditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/step"
          }
        },
        "assertions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "cleanup": {
          "$ref": "#/definitions/cleanup"
        },
        "environment": {
          "$ref": "#/definitions/environment"
        },
        "executors": {
          "$ref": "#/definitions/executors"
        },
        "automation": {
          "$ref": "#/definitions/automation"
        },
        "source": {
          "$ref": "#/definitions/source"
        },
        "linkedBugIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^BUG-[0-9]{3}$"
          }
        },
        "externalReferences": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/externalReference"
          }
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "lastReviewed": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "number",
        "action"
      ],
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "action": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "cleanup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "steps"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targets",
        "roles"
      ],
      "properties": {
        "targets": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "executors": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "devinBrowser",
        "playwright"
      ],
      "properties": {
        "devinBrowser": {
          "enum": [
            "required",
            "eligible",
            "unsupported"
          ]
        },
        "playwright": {
          "enum": [
            "eligible",
            "blocked",
            "unsupported"
          ]
        },
        "blockedReason": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "playwright": {
                "const": "blocked"
              }
            },
            "required": [
              "playwright"
            ]
          },
          "then": {
            "required": [
              "blockedReason"
            ]
          }
        }
      ]
    },
    "automation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "specPath"
      ],
      "properties": {
        "status": {
          "enum": [
            "manual",
            "devin_verified",
            "candidate",
            "implementation_pr",
            "active",
            "quarantined"
          ]
        },
        "specPath": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "reference"
      ],
      "properties": {
        "type": {
          "enum": [
            "migration",
            "manual",
            "exploratory",
            "customer-ticket",
            "production-bug"
          ]
        },
        "reference": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "externalReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system",
        "id"
      ],
      "properties": {
        "system": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    }
  }
}
