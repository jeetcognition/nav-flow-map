# Target environment
BASE_URL=https://cog-enterprise-qa.beta.devinenterprise.com

# Base URL for the API health smoke (usually same host as BASE_URL)
BASE_API_URL=https://cog-enterprise-qa.beta.devinenterprise.com

# Login email (the address you type into the app). Required for automated login.
DEVIN_ADMIN_EMAIL=
# Optional classic password (only for envs that use email+password instead of email+OTP).
DEVIN_ADMIN_PASSWORD=

# --- Automated email-OTP login (recommended for passwordless code login) ---
# auth.setup.ts enters DEVIN_ADMIN_EMAIL, then reads the one-time code from Gmail over IMAP.
# Needs a Google App Password (Account -> Security -> 2-Step Verification -> App passwords),
# NOT your normal Gmail password. 16 chars, spaces optional.
GMAIL_APP_PASSWORD=
# Inbox to read codes from. Defaults to DEVIN_ADMIN_EMAIL if blank.
GMAIL_IMAP_USER=
# Optional filters to disambiguate the OTP email (case-insensitive substrings).
OTP_FROM_INCLUDES=
OTP_SUBJECT_INCLUDES=
# Optional custom code matcher (JS regex, capture group 1). Default matches a 6-digit code.
OTP_CODE_REGEX=

# Member account (optional — only needed for ENT-006 two-context propagation tests)
DEVIN_MEMBER_EMAIL=
DEVIN_MEMBER_PASSWORD=
# Per-role Gmail overrides (fall back to GMAIL_APP_PASSWORD / GMAIL_IMAP_USER if blank)
GMAIL_MEMBER_APP_PASSWORD=
GMAIL_MEMBER_IMAP_USER=
# Set to "1" to trigger a headed manual-login session for the member role without creds
AUTH_MANUAL_MEMBER=

# A known sub-org name that exists in your test enterprise (used in ENT-003 org-switch test)
TEST_SUBORG=devin_suborg_1

# API service keys for the nightly health smoke (ENT-021 / ENT-022)
ENTERPRISE_SERVICE_KEY=
ORG_SERVICE_KEY=
